{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:path:allow-app-data-dir",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "core:asset:default",
    "core:asset:allow-app-data-meta",
    "core:asset:allow-app-data-meta-recursive"
  ]
}
